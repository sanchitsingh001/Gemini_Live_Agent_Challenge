# Narrative Engine — copy to .env (do not commit .env)

GOOGLE_CLOUD_PROJECT=project-363d072c-3554-4f41-b1e
GOOGLE_CLOUD_LOCATION=us-central1
# GA: gemini-2.5-pro (default) or gemini-2.5-flash (faster). Preview: e.g. gemini-3-flash-preview (if enabled)
GEMINI_MODEL=gemini-2.5-pro
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002

# gcloud auth application-default login (once per machine)

# EXPORT_GODOT=0 to skip Godot export on API server
# CHAT_API_BASE=https://your-game-server
# PROJECT_ROOT=/path/to/Narrative_Engine
